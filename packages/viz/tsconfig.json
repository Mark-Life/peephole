{
  "extends": "@workspace/typescript-config/react-library.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "composite": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strictNullChecks": true,
    "paths": {
      "@workspace/ui/*": ["../ui/src/*"],
      "@workspace/core/*": ["../core/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
